import java.util.*;

class Main {
    public static void main(String[] args) {
      Scanner pos = new Scanner(System.in);
      int[] arr = new int[100];
      System.out.println("Enter a number : ");
      int k = pos.nextInt();
      System.out.println("Enter array elements :  ");
      int sum = 0;
      
      for(int i = 0;i<k;i++){
          arr[i] = pos.nextInt();
          sum+=arr[i];
          
      }
      double p = sum / (k);
      System.out.print(p);
    } 
   
}
