import java.util.*;
class Main {
    public static void main(String[] args) {
        System.out.print("Enter a number: ");
        Scanner pos = new Scanner(System.in);
        int k = pos.nextInt();
        if(k % 2 == 0){
            System.out.print("Even");
        }
        else {
            System.out.print("Odd");
        }
  
    }
}
